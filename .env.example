# Frontend local apuntando al Gateway.
VITE_API_BASE_URL=http://localhost:5000/api

# Gateway
PORT=5000
AllowedOrigins=http://localhost:5173,https://front-38m.pages.dev
ReverseProxy__Clusters__identity-cluster__Destinations__identity-dest__Address=http://localhost:5001/
ReverseProxy__Clusters__orders-cluster__Destinations__orders-dest__Address=http://localhost:5002/
ReverseProxy__Clusters__payments-cluster__Destinations__payments-dest__Address=http://localhost:5003/
ReverseProxy__Clusters__reporting-cluster__Destinations__reporting-dest__Address=http://localhost:5004/

# JWT compartido por todos los microservicios.
JWT_SECRET=
JWT_ISSUER=FuelTrack.Api
JWT_AUDIENCE=FuelTrack.Web
JWT_EXPIRATION_MINUTES=120
ENABLE_SWAGGER=true
ASPNETCORE_ENVIRONMENT=Development

# MySQL compartido. Si MYSQLDATABASE queda vacío, cada servicio usa su base por defecto:
# identity_db, orders_db, payments_db o reporting_db.
MYSQLHOST=localhost
MYSQLPORT=3307
MYSQLUSER=root
MYSQLPASSWORD=root
MYSQLDATABASE=

# Alternativa explícita por servicio. Tiene prioridad sobre MYSQL* si se configura.
ConnectionStrings__IdentityConnection=Server=localhost;Port=3307;Database=identity_db;User=root;Password=root;
ConnectionStrings__OrdersConnection=Server=localhost;Port=3307;Database=orders_db;User=root;Password=root;
ConnectionStrings__PaymentsConnection=Server=localhost;Port=3307;Database=payments_db;User=root;Password=root;
ConnectionStrings__ReportingConnection=Server=localhost;Port=3307;Database=reporting_db;User=root;Password=root;
ConnectionStrings__Redis=localhost:6379

# RabbitMQ
RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__Username=admin
RabbitMQ__Password=ChangeMe123
